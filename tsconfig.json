{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@pipeline/*": [
                "./pipeline/*"
            ]
        },
        "baseUrl": ".",
        "types": [
            "vite/client",
            "node"
        ]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.vue",
        "pipeline/**/*.ts",
        "test/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}